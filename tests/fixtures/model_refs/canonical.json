{
  "description": "Canonical model ref parser test cases",
  "contract_version": "1.18.0",
  "cases": [
    {
      "input": "gemma-3b",
      "expected_kind": "model",
      "description": "Plain model name"
    },
    {
      "input": "phi-4-mini",
      "expected_kind": "model",
      "description": "Model with hyphens"
    },
    {
      "input": "@app/translator/chat",
      "expected_kind": "app",
      "expected_app_slug": "translator",
      "expected_capability": "chat"
    },
    {
      "input": "@app/my-app/embeddings",
      "expected_kind": "app",
      "expected_app_slug": "my-app",
      "expected_capability": "embeddings"
    },
    {
      "input": "@capability/chat",
      "expected_kind": "capability",
      "expected_capability": "chat"
    },
    {
      "input": "@capability/embeddings",
      "expected_kind": "capability",
      "expected_capability": "embeddings"
    },
    {
      "input": "deploy_abc123",
      "expected_kind": "deployment",
      "expected_deployment_id": "abc123"
    },
    {
      "input": "deploy_my-deployment-key",
      "expected_kind": "deployment",
      "expected_deployment_id": "my-deployment-key"
    },
    {
      "input": "exp_test1/control",
      "expected_kind": "experiment",
      "expected_experiment_id": "test1",
      "expected_variant_id": "control"
    },
    {
      "input": "exp_ab-test/variant-a",
      "expected_kind": "experiment",
      "expected_experiment_id": "ab-test",
      "expected_variant_id": "variant-a"
    },
    {
      "input": "alias:fast",
      "expected_kind": "alias",
      "expected_alias": "fast"
    },
    {
      "input": "alias:production-model",
      "expected_kind": "alias",
      "expected_alias": "production-model"
    },
    { "input": "", "expected_kind": "default" },
    { "input": "@unknown/scope/path", "expected_kind": "unknown" },
    { "input": "https://example.com/model", "expected_kind": "unknown" },
    {
      "input": "deploy_",
      "expected_kind": "deployment",
      "expected_deployment_id": "",
      "description": "Edge case: empty deployment ID"
    },
    {
      "input": "@app/slug",
      "expected_kind": "unknown",
      "description": "App ref without capability"
    }
  ]
}
